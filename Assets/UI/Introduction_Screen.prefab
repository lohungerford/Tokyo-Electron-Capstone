  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "The goal of this game is to correctly handle as many open floor tiles
    as possible before the level timer runs out. You can do this by blocking friendly
    robots from falling through them and avoiding falling through them yourself.\n\nIn
    some levels, there will be enemy robots present. These robots will try to attack
    you if you get within range, so use power-ups to deactivate them.\n\nThere is
    also a puzzle available in each level. This puzzle, if completed before the timer
    is up, allows the player to end the level early and get a point boost. \n\nAim
    to maximize points by safely guiding friendly robots out of the fab, deactivating
    enemy robots, and completing the puzzle!"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
